@page "/q/{Code}"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject ILogger<QRUnlockRedirect> Logger

<PageTitle>Unlock - Project 400</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    @if (isLoading)
    {
        <MudCard>
            <MudCardContent Class="d-flex flex-column align-center justify-center" Style="min-height: 200px;">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                <MudText Class="mt-3">Verifying unlock code...</MudText>
            </MudCardContent>
        </MudCard>
    }
    else if (hasError)
    {
        <MudCard>
            <MudCardContent>
                <MudAlert Severity="Severity.Error">
                    <MudText Typo="Typo.h6">Code Expired</MudText>
                    <MudText>This unlock code has expired or is invalid. Please scan a fresh QR code at the door.</MudText>
                </MudAlert>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Href="/"
                           Class="mt-4"
                           FullWidth="true">
                    Back to Dashboard
                </MudButton>
            </MudCardContent>
        </MudCard>
    }
</MudContainer>

@code {
    [Parameter]
    public string? Code { get; set; }

    private bool isLoading = true;
    private bool hasError = false;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Code))
        {
            hasError = true;
            isLoading = false;
            return;
        }

        try
        {
            var http = HttpClientFactory.CreateClient("Project400API");
            Logger.LogInformation("Looking up unlock code: {Code}", Code);
            var response = await http.GetAsync($"/api/unlock/by-code/{Code}");

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<CodeLookupResponse>();
                if (result?.RequestId != null && result.RequestId != Guid.Empty)
                {
                    Logger.LogInformation("Code {Code} resolved to request {RequestId}, redirecting", Code, result.RequestId);
                    Navigation.NavigateTo($"/unlock-approval/{result.RequestId}", forceLoad: true);
                    return;
                }
            }

            Logger.LogWarning("Code lookup failed: {Code}, status: {Status}", Code, response.StatusCode);
            hasError = true;
        }
        catch (NavigationException)
        {
            throw;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error looking up unlock code: {Code}", Code);
            hasError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private class CodeLookupResponse
    {
        public Guid RequestId { get; set; }
    }
}
